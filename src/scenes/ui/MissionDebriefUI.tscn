[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/mission_debrief_ui.gd" id="1_debrief"]

; process_mode=3 (PROCESS_MODE_ALWAYS) — continues running while tree is paused.
[node name="MissionDebriefUI" type="CanvasLayer"]
layer = 110
process_mode = 3
script = ExtResource("1_debrief")

; Semi-transparent black overlay behind the panel.
[node name="Overlay" type="ColorRect" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.5)

; Centered debrief panel — 600x640px.
[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -320.0
offset_right = 300.0
offset_bottom = 320.0

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 10

; ── Outcome banner ───────────────────────────────────────────────────────────
[node name="OutcomeBanner" type="ColorRect" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 120)
color = Color(0, 0.784, 0, 1)

[node name="BannerVBox" type="VBoxContainer" parent="Panel/VBox/OutcomeBanner"]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
alignment = 1

[node name="OutcomeLabel" type="Label" parent="Panel/VBox/OutcomeBanner/BannerVBox"]
layout_mode = 2
text = "SUCCEEDED"
horizontal_alignment = 1

[node name="FlavorLabel" type="Label" parent="Panel/VBox/OutcomeBanner/BannerVBox"]
layout_mode = 2
text = "Well done, agent."
horizontal_alignment = 1

; ── Objectives section ───────────────────────────────────────────────────────
[node name="ObjectivesTitle" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "OBJECTIVES"

[node name="ObjectiveList" type="VBoxContainer" parent="Panel/VBox"]
layout_mode = 2

; ── XP earned section ────────────────────────────────────────────────────────
[node name="XPTitle" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "XP EARNED"

[node name="XPLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "0"
horizontal_alignment = 2

; ── Loot section ─────────────────────────────────────────────────────────────
[node name="LootTitle" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "LOOT"

[node name="LootLabel" type="Label" parent="Panel/VBox"]
layout_mode = 2
text = "No items collected"

; ── Continue button ───────────────────────────────────────────────────────────
[node name="ContinueButton" type="Button" parent="Panel/VBox"]
layout_mode = 2
text = "CONTINUE"
disabled = true
